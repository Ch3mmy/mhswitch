# ----------------- Latency Test -----------------
delay_test_group() {
  local group="$1"
  local test_url="${2:-$DELAY_URL_DEFAULT}"
  local timeout_ms="${3:-$DELAY_TIMEOUT_DEFAULT}"
  local jobs="${4:-$DELAY_JOBS_DEFAULT}"

  if ! controller_alive; then
    ui_error "Mihomo 未运行"
    ui_info "请先执行: mhswitch start"
    return 1
  fi

  python3 - "$CONTROLLER" "$SECRET" "$group" "$test_url" "$timeout_ms" "$jobs" <<'PY'
import concurrent.futures
import json
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

controller, secret, group, test_url, timeout_ms, jobs = sys.argv[1:7]
timeout_ms = int(timeout_ms)
jobs = max(1, int(jobs))

headers = {}
if secret:
    headers['Authorization'] = f'Bearer {secret}'

def api_get(path, timeout=None):
    url = controller.rstrip('/') + path
    req = urllib.request.Request(url, headers=headers, method='GET')
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read().decode('utf-8', errors='replace')
    return json.loads(raw) if raw else {}

def safe_get_group(g):
    try:
        return api_get('/proxies/' + urllib.parse.quote(g, safe=''), timeout=10)
    except urllib.error.HTTPError as e:
        sys.exit(f'读取策略组失败: {g}，HTTP {e.code}')
    except Exception as e:
        sys.exit(f'读取策略组失败: {g}，{e}')

info = safe_get_group(group)
nodes = info.get('all') or []

if not nodes:
    nodes = [group]

skip = {'DIRECT', 'REJECT', 'REJECT-DROP', 'PASS'}
seen = set()
clean_nodes = []
for n in nodes:
    if n in skip or n in seen:
        continue
    seen.add(n)
    clean_nodes.append(n)

if not clean_nodes:
    print(f'策略组 [{group}] 中没有可检测节点。')
    sys.exit(0)

print(f'正在检测 [{group}]，节点数: {len(clean_nodes)}，测试地址: {test_url}，超时: {timeout_ms}ms，并发: {jobs}')

def test_one(node):
    path = (
        '/proxies/' + urllib.parse.quote(node, safe='') +
        '/delay?timeout=' + str(timeout_ms) +
        '&url=' + urllib.parse.quote(test_url, safe='')
    )
    started = time.time()
    try:
        data = api_get(path, timeout=timeout_ms / 1000 + 5)
        delay = data.get('delay')
        if isinstance(delay, int) and delay >= 0:
            return {'node': node, 'delay': delay, 'ok': True, 'error': ''}
        return {'node': node, 'delay': None, 'ok': False, 'error': data.get('message') or 'no delay'}
    except Exception as e:
        elapsed = int((time.time() - started) * 1000)
        msg = str(e).replace('\n', ' ')[:80]
        return {'node': node, 'delay': None, 'ok': False, 'error': msg or f'timeout>{elapsed}ms'}

results = []
with concurrent.futures.ThreadPoolExecutor(max_workers=jobs) as ex:
    futures = [ex.submit(test_one, n) for n in clean_nodes]
    for fut in concurrent.futures.as_completed(futures):
        results.append(fut.result())

results.sort(key=lambda x: (not x['ok'], x['delay'] if x['delay'] is not None else 10**9, x['node']))

node_width = max(4, min(64, max(len(r['node']) for r in results)))
print('-' * (node_width + 24))
print(f"{'延迟(ms)':>10}  {'状态':<6}  {'节点':<{node_width}}")
print('-' * (node_width + 24))
for r in results:
    if r['ok']:
        delay_text = str(r['delay'])
        status = 'OK'
    else:
        delay_text = '-'
        status = 'FAIL'
    name = r['node']
    if len(name) > node_width:
        name = name[:node_width - 1] + '…'
    print(f"{delay_text:>10}  {status:<6}  {name:<{node_width}}")

ok = [r for r in results if r['ok']]
fail = len(results) - len(ok)
print('-' * (node_width + 24))
if ok:
    best = ok[0]
    print(f"最快节点: {best['node']} ({best['delay']} ms)")
print(f"可用: {len(ok)} / {len(results)}，失败: {fail}")
PY
}

delay_all_airports() {
  local test_url="${1:-$DELAY_URL_DEFAULT}"
  local timeout_ms="${2:-$DELAY_TIMEOUT_DEFAULT}"
  local jobs="${3:-$DELAY_JOBS_DEFAULT}"
  local count=0

  while IFS=$'\t' read -r id name url exclude; do
    [[ -s "$(provider_abs "$id")" ]] || continue
    count=$((count + 1))
    ui_section "机场: $name"
    delay_test_group "${name}-手动" "$test_url" "$timeout_ms" "$jobs" || true
  done < <(state_iter)

  if [[ $count -eq 0 ]]; then
    ui_warn "没有可检测的机场"
    ui_info "请先执行: mhswitch add <订阅URL> [名称]"
  fi
}

run_delay() {
  local target="${1:-all}"
  local test_url="${2:-$DELAY_URL_DEFAULT}"
  local timeout_ms="${3:-$DELAY_TIMEOUT_DEFAULT}"
  local jobs="${4:-$DELAY_JOBS_DEFAULT}"
  local id name group

  if [[ "$target" == "all" || "$target" == "全部" ]]; then
    delay_all_airports "$test_url" "$timeout_ms" "$jobs"
    return 0
  fi

  if id="$(resolve_id "$target" 2>/dev/null)"; then
    name="$(airport_name_by_id "$id")"
    group="${name}-手动"
    delay_test_group "$group" "$test_url" "$timeout_ms" "$jobs"
    return 0
  fi

  delay_test_group "$target" "$test_url" "$timeout_ms" "$jobs"
}

run_openai_test() {
  local target="${1:-all}"
  local timeout_ms="${2:-$OPENAI_TEST_TIMEOUT_DEFAULT}"
  local jobs="${3:-$DELAY_JOBS_DEFAULT}"
  local id name group count=0

  ui_title "OpenAI 网站支持检测"
  ui_kv "固定地区" "$AI_REGION_NAME"
  ui_kv "测试地址" "$OPENAI_TEST_URL"
  ui_end

  case "$target" in
    all|best|auto|全部|最优|"")
      group="$OPENAI_AUTO_GROUP"
      delay_test_group "$group" "$OPENAI_TEST_URL" "$timeout_ms" "$jobs"
      return 0
      ;;
    strict|region|fixed|固定|固定地区)
      group="OpenAI-${AI_REGION_NAME}-最优"
      delay_test_group "$group" "$OPENAI_TEST_URL" "$timeout_ms" "$jobs"
      return 0
      ;;
    global|any|all-region|全局|全地区)
      group="$OPENAI_GLOBAL_GROUP"
      delay_test_group "$group" "$OPENAI_TEST_URL" "$timeout_ms" "$jobs"
      return 0
      ;;
    each|airports|逐机场|机场)
      while IFS=$'\t' read -r id name url exclude; do
        [[ -s "$(provider_abs "$id")" ]] || continue
        count=$((count + 1))
        ui_section "机场: $name"
        delay_test_group "OpenAI-${name}-${AI_REGION_NAME}" "$OPENAI_TEST_URL" "$timeout_ms" "$jobs" || true
      done < <(state_iter)
      if [[ $count -eq 0 ]]; then
        ui_warn "没有可检测的机场"
        ui_info "请先执行: mhswitch add <订阅URL> [名称]"
      fi
      return 0
      ;;
    *)
      if id="$(resolve_id "$target" 2>/dev/null)"; then
        name="$(airport_name_by_id "$id")"
        group="OpenAI-${name}-${AI_REGION_NAME}"
      else
        group="$target"
      fi
      delay_test_group "$group" "$OPENAI_TEST_URL" "$timeout_ms" "$jobs"
      ;;
  esac
}

# ----------------- VPN Control Commands -----------------
set_group_proxy() {
  local group="$1" target="$2"
  if ! controller_alive; then
    ui_error "Mihomo 未运行"
    return 1
  fi
  curl_api PUT "/proxies/$(urlenc "$group")" -H 'Content-Type: application/json' -d "{\"name\":$(json_quote "$target")}" >/dev/null
  ui_ok "策略已切换"
  ui_kv_arrow "$group" "$target"
}

set_mode() {
  local mode="$1"
  mode="$(echo "$mode" | tr '[:upper:]' '[:lower:]')"
  [[ "$mode" =~ ^(rule|global|direct)$ ]] || { ui_error "模式必须是 rule、global 或 direct"; return 1; }
  if ! controller_alive; then
    ui_error "Mihomo 未运行"
    return 1
  fi
  curl_api PATCH "/configs" -H 'Content-Type: application/json' -d "{\"mode\":\"$mode\"}" >/dev/null
  ui_ok "代理模式已切换"
  ui_kv "模式" "$mode"
}

flush_connections() {
  if ! controller_alive; then
    ui_error "Mihomo 未运行"
    return 1
  fi
  curl_api DELETE "/connections" >/dev/null
  ui_ok "已切断所有现有连接"
}

show_git_clone_proxy() {
  local now="-"
  if controller_alive; then
    now="$(curl_api GET "/proxies/$(urlenc "$GIT_GROUP_NAME")" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('now') or '-')" 2>/dev/null || echo "读取失败")"
  fi
  ui_title "Git Clone 代理"
  ui_kv_arrow "$GIT_GROUP_NAME" "$now"
  ui_end
}

set_git_clone_proxy() {
  local arg="${1:-status}"
  local target=""
  local id=""
  local name=""

  case "$arg" in
    status|状态)
      show_git_clone_proxy
      return 0
      ;;
    direct|off|no|false|0|直连)
      target="DIRECT"
      ;;
    proxy|on|yes|true|1|代理)
      target="默认代理"
      ;;
    best|auto|all|全部|最优)
      target="最优节点"
      ;;
    *)
      if id="$(resolve_id "$arg" 2>/dev/null)"; then
        name="$(airport_name_by_id "$id")"
        target="${name}-自动"
      else
        target="$arg"
      fi
      ;;
  esac

  set_group_proxy "$GIT_GROUP_NAME" "$target"
}

show_status() {
  local mode="unknown"
  local default_now="-"
  local claude_now="-"
  local openai_now="-"
  local git_now="-"
  local version="-"
  local service="❌ 未运行"

  if controller_alive; then
    service="✅ 运行中"
    mode="$(curl_api GET "/configs" | python3 -c "import sys,json; print(json.load(sys.stdin).get('mode', 'unknown'))" 2>/dev/null || echo "unknown")"
    version="$(curl_api GET "/version" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('version') or d.get('meta') or '-')" 2>/dev/null || echo "-")"
    default_now="$(curl_api GET "/proxies/默认代理" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('now') or '-')" 2>/dev/null || echo "读取失败")"
    claude_now="$(curl_api GET "/proxies/Claude" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('now') or '-')" 2>/dev/null || echo "读取失败")"
    openai_now="$(curl_api GET "/proxies/OpenAI" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('now') or '-')" 2>/dev/null || echo "读取失败")"
    git_now="$(curl_api GET "/proxies/$(urlenc "$GIT_GROUP_NAME")" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('now') or '-')" 2>/dev/null || echo "读取失败")"
  fi

  local airport_count=0
  local airports_text=""
  while IFS=$'\t' read -r id name url exclude; do
    airport_count=$((airport_count + 1))
    airports_text+="  $airport_count. $name
"
  done < <(state_iter)
  [[ $airport_count -eq 0 ]] && airports_text="  (无)
"

  ui_title "mhswitch 状态"
  ui_kv "服务" "$service"
  ui_kv "控制器" "$CONTROLLER"
  ui_kv "模式" "$mode"
  ui_kv "版本" "$version"
  ui_kv "配置" "$CONFIG_FILE"
  ui_kv "AI 固定地区" "$AI_REGION_NAME"
  ui_kv "OpenAI 检测地址" "$OPENAI_TEST_URL"
  ui_kv "OpenAI 检测超时" "${OPENAI_TEST_TIMEOUT_DEFAULT}ms"
  ui_kv "AI 额外排除" "${AI_EXCLUDE_FILTER:-(无)}"
  ui_kv "故障检查间隔" "${FAILOVER_INTERVAL_DEFAULT}s"
  ui_kv "故障超时阈值" "${FAILOVER_TIMEOUT_DEFAULT}ms"
  ui_end

  ui_title "当前策略"
  ui_kv_arrow "默认代理" "$default_now"
  ui_kv_arrow "Claude" "$claude_now"
  ui_kv_arrow "OpenAI/Codex" "$openai_now"
  ui_kv_arrow "Git Clone" "$git_now"
  ui_end

  ui_title "已配置机场: ${airport_count} 个"
  printf "%s" "$airports_text"
  ui_end

  echo
  if ! controller_alive; then
    echo "提示: 可使用 mhswitch start 启动 Mihomo。"
  else
    echo "常用: mhswitch openai-test  检测 OpenAI 支持    mhswitch openai best  Codex 地区优先+兜底"
  fi
}

