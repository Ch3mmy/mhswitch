reload_config() {
  if controller_alive; then
    curl_api PUT "/configs?force=true" -H 'Content-Type: application/json' -d "{\"path\":$(json_quote "$CONFIG_FILE")}" >/dev/null || true
    ui_ok "配置已热重载"
    ui_kv "配置" "$CONFIG_FILE"
  else
    start_mihomo || true
  fi
}

refresh_all() {
  local updated=0
  while IFS=$'\t' read -r id name url exclude; do
    if [[ -n "$url" ]]; then
      ui_run "更新机场: $name"
      if download_subscription "$url" "$(full_abs "$id")"; then
        analyze_sub "$(full_abs "$id")" "$(provider_abs "$id")" "$name" "$id" >/dev/null
        updated=1
      fi
    fi
  done < <(state_iter)

  if [[ $updated -eq 1 ]]; then
    generate_config && reload_config
    ui_ok "所有订阅已更新完毕"
  else
    ui_warn "没有可更新的机场"
  fi
}

# ----------------- Node Inventory -----------------
print_provider_nodes() {
  local provider_file="$1"
  local exclude_regex="${2:-}"

  python3 - "$provider_file" "$exclude_regex" <<'PY'
import re
import sys

path, exclude_regex = sys.argv[1], sys.argv[2]

try:
    text = open(path, 'r', encoding='utf-8', errors='ignore').read()
except FileNotFoundError:
    print('  (provider 文件不存在，请先执行 mhswitch update)')
    sys.exit(0)

names = []
for line in text.splitlines():
    m = re.search(r"name:\s*(?:'([^']*)'|\"([^\"]*)\"|([^,}#]+))", line)
    if not m:
        continue
    name = next((x for x in m.groups() if x is not None), '').strip()
    if name:
        names.append(name)

if not names:
    print('  (未解析到节点)')
    sys.exit(0)

exclude = None
if exclude_regex:
    try:
        exclude = re.compile(exclude_regex)
    except re.error:
        exclude = None

print(f'  节点数: {len(names)}')
for i, name in enumerate(names, 1):
    mark = ''
    if exclude and exclude.search(name):
        mark = '  (exclude-filter)'
    print(f'  {i:>3}. {name}{mark}')
PY
}

show_airport_nodes() {
  local id="$1"
  local name="$2"
  local exclude="${3:-}"
