  pabs="$(provider_abs "$id")"
  ui_title "机场节点: $name"
  print_provider_nodes "$pabs" "$exclude"
  ui_end
}

list_nodes() {
  local target="${1:-all}"
  local id name url exclude
  local found=0

  case "$target" in
    all|全部|"")
      while IFS=$'\t' read -r id name url exclude; do
        found=1
        show_airport_nodes "$id" "$name" "$exclude"
      done < <(state_iter)
      if [[ $found -eq 0 ]]; then
        ui_warn "没有已配置机场"
        ui_info "请先执行: mhswitch add <订阅URL> [名称]"
      fi
      ;;
    *)
      id="$(resolve_id "$target")" || { ui_error "未找到机场: $target"; return 1; }
      while IFS=$'\t' read -r id2 name url exclude; do
        [[ "$id2" == "$id" ]] || continue
        show_airport_nodes "$id2" "$name" "$exclude"
        found=1
        break
      done < <(state_iter)
      [[ $found -eq 1 ]] || { ui_error "未找到机场: $target"; return 1; }
      ;;
  esac
}

