#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="${MIHOMO_HOME:-$HOME/.config/mihomo}"
PROVIDERS_DIR="$BASE_DIR/providers"
STATE_FILE="$BASE_DIR/mhswitch-state.json"
CONFIG_FILE="$BASE_DIR/config.yaml"
CONTROLLER="${MIHOMO_CONTROLLER:-http://127.0.0.1:9090}"
SECRET="${MIHOMO_SECRET:-}"
MIHOMO_BIN="${MIHOMO_BIN:-}"
PID_FILE="$BASE_DIR/mihomo.pid"
MIHOMO_INSTALL_DIR="${MHSWITCH_MIHOMO_INSTALL_DIR:-$HOME/.local/bin}"
MIHOMO_RELEASE_LATEST_URL="${MHSWITCH_MIHOMO_RELEASE_LATEST_URL:-https://github.com/MetaCubeX/mihomo/releases/latest}"
MIHOMO_RELEASE_BASE_URL="${MHSWITCH_MIHOMO_RELEASE_BASE_URL:-https://github.com/MetaCubeX/mihomo/releases/download}"

# ----------------- AI 地区固定策略 -----------------
# 默认：OpenAI / Claude / Codex 只在美国节点里故障切换。
# 与 url-test 不同，fallback 不会因为延迟更低而主动切换；只有当前节点 timeout / 不可用才切换。
# 你可以通过环境变量覆盖，例如：
#   export MHSWITCH_AI_REGION_NAME="日本"
#   export MHSWITCH_AI_REGION_FILTER='(?i)(🇯🇵|日本|JP|Japan|Tokyo|Osaka)'
AI_REGION_NAME="${MHSWITCH_AI_REGION_NAME:-美国}"
AI_REGION_FILTER="${MHSWITCH_AI_REGION_FILTER:-(?i)(🇺🇸|美国|US|United States|America|USA)}"

# OpenAI / ChatGPT 健康检查地址：
# - 默认使用 chatgpt.com/cdn-cgi/trace，优点是轻量、无需登录、能真实检测 ChatGPT 域名可达性；
# - 这不是 OpenAI API 权限检测，只表示该节点能连通 ChatGPT/OpenAI 相关域名。
OPENAI_TEST_URL="${MHSWITCH_OPENAI_TEST_URL:-https://chatgpt.com/cdn-cgi/trace}"
OPENAI_TEST_TIMEOUT_DEFAULT="${MHSWITCH_OPENAI_TEST_TIMEOUT:-10000}"
CLAUDE_TEST_URL="${MHSWITCH_CLAUDE_TEST_URL:-https://claude.ai}"

# AI 节点额外排除规则：默认排除日志里容易卡住的 DRT/MIX 类节点。
# 如需关闭排除：export MHSWITCH_AI_EXCLUDE_FILTER=''
AI_EXCLUDE_FILTER="${MHSWITCH_AI_EXCLUDE_FILTER-[Dd][Rr][Tt]|[Mm][Ii][Xx]}"
OPENAI_AUTO_GROUP="OpenAI-可用优先"
OPENAI_GLOBAL_GROUP="OpenAI-全地区-最优"

# 延迟检测默认参数，可通过环境变量覆盖：
#   MHSWITCH_DELAY_URL="https://www.gstatic.com/generate_204"
#   MHSWITCH_DELAY_TIMEOUT=5000
#   MHSWITCH_DELAY_JOBS=12
DELAY_URL_DEFAULT="${MHSWITCH_DELAY_URL:-https://www.gstatic.com/generate_204}"
DELAY_TIMEOUT_DEFAULT="${MHSWITCH_DELAY_TIMEOUT:-5000}"
DELAY_JOBS_DEFAULT="${MHSWITCH_DELAY_JOBS:-12}"

# ----------------- 节点故障切换策略 -----------------
# 目标：定时健康检查，但只有 timeout / 不可用时才切换；
# 不因为“延迟更低”或“当前延迟偏高”主动切换。
#
# 可通过环境变量覆盖：
#   MHSWITCH_FAILOVER_INTERVAL=300
#   MHSWITCH_FAILOVER_TIMEOUT=5000
#   MHSWITCH_FAILOVER_LAZY=false
FAILOVER_INTERVAL_DEFAULT="${MHSWITCH_FAILOVER_INTERVAL:-300}"
FAILOVER_TIMEOUT_DEFAULT="${MHSWITCH_FAILOVER_TIMEOUT:-5000}"
FAILOVER_LAZY_DEFAULT="${MHSWITCH_FAILOVER_LAZY:-false}"

# ----------------- Git Clone 代理策略 -----------------
# 默认：git clone 直连，避免拉取代码时被代理影响。
# 可通过环境变量覆盖：
#   export MHSWITCH_GIT_PROXY_DEFAULT="proxy"   # direct / proxy / best，也可填具体策略组名
#   export MHSWITCH_GIT_GROUP_NAME="Git Clone"  # 自定义策略组名
GIT_GROUP_NAME="${MHSWITCH_GIT_GROUP_NAME:-Git Clone}"
GIT_PROXY_DEFAULT="${MHSWITCH_GIT_PROXY_DEFAULT:-direct}"

# ----------------- UI Helper -----------------
if [[ -n "${MHSWITCH_NO_EMOJI:-}" ]]; then
  I_OK="OK"; I_WARN="!!"; I_ERR="XX"; I_INFO="--"; I_RUN=">>"
else
  I_OK="✅"; I_WARN="⚠️"; I_ERR="❌"; I_INFO="ℹ️"; I_RUN="▶️"
fi

ui_title() { echo "╭──────────────── $1 ────────────────╮"; }
ui_end() { echo "╰────────────────────────────────────╯"; }
ui_line() { echo "──────────────────────────────────────"; }
ui_section() { echo; echo "▍$1"; }
ui_ok() { echo "$I_OK $*"; }
ui_info() { echo "$I_INFO $*"; }
ui_warn() { echo "$I_WARN $*" >&2; }
ui_error() { echo "$I_ERR $*" >&2; }
ui_run() { echo "$I_RUN $*"; }
ui_kv() { echo "  $1: $2"; }
ui_kv_arrow() { echo "  $1 → $2"; }

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { ui_error "缺少命令: $1"; exit 1; }
}

need_cmd curl
need_cmd python3

mkdir -p "$PROVIDERS_DIR"

# ----------------- Python / API Helper -----------------
json_quote() {
  # 纯 Bash JSON 字符串转义，避免生成配置时反复启动 Python。
  local s="${1-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '"%s"\n' "$s"
}

urlenc() {
  python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1"
}

pretty_json() {
  if command -v jq >/dev/null 2>&1; then jq .
  else python3 -m json.tool; fi
}

curl_api() {
  local method="$1"; shift
  local path="$1"; shift || true
  local -a cmd=(curl -fsSL -X "$method")
  [[ -n "$SECRET" ]] && cmd+=( -H "Authorization: Bearer $SECRET" )
  cmd+=( "$CONTROLLER$path" )
  (($# > 0)) && cmd+=( "$@" )
  "${cmd[@]}" 2>/dev/null
}

controller_alive() {
  curl_api GET "/version" >/dev/null 2>&1
}

merge_regex() {
  # 合并两个正则字符串；任意一个为空则返回另一个。
  # 这里不主动包裹 (?:...)，避免与 Mihomo/Go regexp 的实现细节冲突。
  local a="${1:-}" b="${2:-}"
  if [[ -n "$a" && -n "$b" ]]; then
    echo "$a|$b"
  elif [[ -n "$a" ]]; then
    echo "$a"
  else
    echo "$b"
  fi
}

# ----------------- State Management -----------------
init_state() {
  [[ -f "$STATE_FILE" ]] && return 0
  echo '{"airports": []}' > "$STATE_FILE"
}

# 遍历所有机场: 返回 id, name, url, exclude_regex
state_iter() {
  python3 - "$STATE_FILE" <<'PY'
import json, sys
try:
    with open(sys.argv[1], encoding='utf-8') as f:
        data = json.load(f)
    for a in data.get('airports', []):
        print(f"{a['id']}\t{a['name']}\t{a.get('url','')}\t{a.get('exclude_regex','')}")
except Exception:
    pass
PY
}

state_remove() {
  local target_id="$1"
  python3 - "$STATE_FILE" "$target_id" <<'PY'
import json, sys
path, target = sys.argv[1], sys.argv[2]
with open(path, encoding='utf-8') as f:
    data = json.load(f)
data['airports'] = [a for a in data.get('airports', []) if a['id'] != target]
with open(path, 'w', encoding='utf-8') as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
PY
}

resolve_id() {
  local q="${1:-}"
  python3 - "$STATE_FILE" "$q" <<'PY'
import json, sys
path, q = sys.argv[1], sys.argv[2].strip().lower().replace(' ', '')
try:
    with open(path, encoding='utf-8') as f:
        data = json.load(f)
    for a in data.get('airports', []):
        cands = {a['id'].lower(), a['name'].lower().replace(' ', '')}
        cands.update([x.lower().replace(' ', '') for x in a.get('aliases', [])])
        if q in cands:
            print(a['id'])
            sys.exit(0)
    sys.exit(1)
except Exception:
    sys.exit(1)
PY
}

airport_name_by_id() {
  local target_id="$1"
  state_iter | awk -F'\t' -v tid="$target_id" '$1 == tid {print $2; exit}'
}

provider_abs() { echo "$PROVIDERS_DIR/${1}_provider.yaml"; }
full_abs() { echo "$PROVIDERS_DIR/${1}_full.yaml"; }

is_interactive_tty() {
  [[ -n "${MHSWITCH_FORCE_INTERACTIVE:-}" || ( -t 0 && -t 1 ) ]]
}

MENU_BACK="__mhswitch_back__"
menu_is_back() {
  [[ "${1:-}" == "$MENU_BACK" ]]
}

choose_menu() {
  local title="$1"
  local context_label="${2:-}"
  local context_value="${3:-}"
  local idx=0
  local key rest

  while true; do
    printf '\033[2J\033[H'
    ui_title "$title"
    [[ -n "$context_label" ]] && ui_kv "$context_label" "$context_value"
    ui_kv "操作" "↑/↓ 或 k/j 移动，Enter 进入，Esc/q 返回"
    ui_end
    echo

    for i in "${!MENU_LABELS[@]}"; do
      if (( i == idx )); then
        printf '  > %s\n' "${MENU_LABELS[$i]}"
      else
        printf '    %s\n' "${MENU_LABELS[$i]}"
      fi
    done

    key=""
    IFS= read -rsn1 key || return 130
    case "$key" in
      "")
        MENU_SELECTION="${MENU_VALUES[$idx]}"
        MENU_SELECTION_LABEL="${MENU_LABELS[$idx]}"
        return 0
        ;;
      $'\x1b')
        rest=""
        if IFS= read -rsn2 -t 0.05 rest; then
          case "$rest" in
            "[A") idx=$(( (idx - 1 + ${#MENU_LABELS[@]}) % ${#MENU_LABELS[@]} )) ;;
            "[B") idx=$(( (idx + 1) % ${#MENU_LABELS[@]} )) ;;
            *) MENU_SELECTION="$MENU_BACK"; MENU_SELECTION_LABEL="返回"; return 0 ;;
          esac
        else
          MENU_SELECTION="$MENU_BACK"
          MENU_SELECTION_LABEL="返回"
          return 0
        fi
        ;;
      k|K)
        idx=$(( (idx - 1 + ${#MENU_LABELS[@]}) % ${#MENU_LABELS[@]} ))
        ;;
      j|J)
        idx=$(( (idx + 1) % ${#MENU_LABELS[@]} ))
        ;;
      q|Q)
        MENU_SELECTION="$MENU_BACK"
        MENU_SELECTION_LABEL="返回"
        return 0
        ;;
    esac
  done
}

choose_openai_target_interactive() {
  if ! is_interactive_tty; then
    ui_error "当前不是交互式终端，无法使用上下键选择"
    ui_info "可用命令: mhswitch openai best|strict|global|direct|机场名 [auto|strict|global]"
    return 1
  fi

  local id name url exclude airport_choice airport_label rule_choice

  while true; do
    MENU_LABELS=("全部机场" "DIRECT")
    MENU_VALUES=("all" "direct")

    while IFS=$'\t' read -r id name url exclude; do
      [[ -s "$(provider_abs "$id")" ]] || continue
      MENU_LABELS+=("$name")
      MENU_VALUES+=("airport:$id")
    done < <(state_iter)

    MENU_SELECTION=""
    MENU_SELECTION_LABEL=""
    choose_menu "选择 OpenAI/Codex 机场范围" "固定地区" "$AI_REGION_NAME" || return $?
    menu_is_back "$MENU_SELECTION" && return 130
    airport_choice="$MENU_SELECTION"
    airport_label="$MENU_SELECTION_LABEL"

    if [[ "$airport_choice" == "direct" ]]; then
      OPENAI_TARGET_SELECTION="DIRECT"
      printf '\033[2J\033[H'
      ui_ok "已选择 OpenAI/Codex 策略"
      ui_kv "机场范围" "$airport_label"
      ui_kv_arrow "OpenAI" "$OPENAI_TARGET_SELECTION"
      return 0
    fi

    if [[ "$airport_choice" == "all" ]]; then
      MENU_LABELS=("${AI_REGION_NAME} 优先 + 全地区兜底" "仅固定 ${AI_REGION_NAME} 地区" "全地区 OpenAI 检测组")
      MENU_VALUES=("$OPENAI_AUTO_GROUP" "OpenAI-${AI_REGION_NAME}-最优" "$OPENAI_GLOBAL_GROUP")
    else
      id="${airport_choice#airport:}"
      name="$(airport_name_by_id "$id")"
      MENU_LABELS=("${name}: ${AI_REGION_NAME} 优先 + 全地区兜底" "${name}: 仅固定 ${AI_REGION_NAME} 地区" "${name}: 全地区 OpenAI 检测组")
      MENU_VALUES=("OpenAI-${name}-可用优先" "OpenAI-${name}-${AI_REGION_NAME}" "OpenAI-${name}-全地区-最优")
    fi

    MENU_SELECTION=""
    MENU_SELECTION_LABEL=""
    choose_menu "选择 OpenAI/Codex 规则" "机场范围" "$airport_label" || return $?
    menu_is_back "$MENU_SELECTION" && continue
    rule_choice="$MENU_SELECTION_LABEL"
    OPENAI_TARGET_SELECTION="$MENU_SELECTION"

    printf '\033[2J\033[H'
    ui_ok "已选择 OpenAI/Codex 策略"
    ui_kv "机场范围" "$airport_label"
    ui_kv "规则" "$rule_choice"
    ui_kv_arrow "OpenAI" "$OPENAI_TARGET_SELECTION"
    return 0
  done
}

emit_process_path_rule() {
  local path="$1" group="$2"
  [[ -n "$path" ]] || return 0
  echo "  - $(json_quote "PROCESS-PATH,$path,$group")"
}

emit_process_rules() {
  local process="$1" group="$2"
  local bin_path="" real_path="" real_name=""

  echo "  - $(json_quote "PROCESS-NAME,$process,$group")"
  echo "  - $(json_quote "PROCESS-NAME,$process (deleted),$group")"
  echo "  - $(json_quote "PROCESS-NAME-WILDCARD,$process*,$group")"

  if bin_path="$(command -v "$process" 2>/dev/null)"; then
    emit_process_path_rule "$bin_path" "$group"
    real_path="$(readlink -f "$bin_path" 2>/dev/null || true)"
    if [[ -n "$real_path" && "$real_path" != "$bin_path" ]]; then
      emit_process_path_rule "$real_path" "$group"
      real_name="$(basename "$real_path")"
      if [[ -n "$real_name" && "$real_name" != "$process" ]]; then
        echo "  - $(json_quote "PROCESS-NAME,$real_name,$group")"
        echo "  - $(json_quote "PROCESS-NAME,$real_name (deleted),$group")"
        echo "  - $(json_quote "PROCESS-NAME-WILDCARD,$real_name*,$group")"
      fi
    fi
  fi
}

emit_domestic_direct_rules() {
  cat <<'EOF'
  # Domestic and private networks are always DIRECT.
  - GEOSITE,private,DIRECT
  - GEOIP,private,DIRECT,no-resolve
  - GEOSITE,cn,DIRECT
  - GEOIP,CN,DIRECT,no-resolve
EOF
}

emit_browser_process_rules() {
  local group="$1"
  local browser
  for browser in \
    firefox firefox-bin \
    microsoft-edge microsoft-edge-stable msedge \
    chromium chromium-browser \
    google-chrome google-chrome-stable \
    brave-browser vivaldi vivaldi-bin opera opera-stable; do
    emit_process_rules "$browser" "$group"
  done
}

# ----------------- Daemon Control -----------------
mihomo_asset_arch() {
  case "${1:-$(uname -m)}" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    armv7l|armv7) echo "armv7" ;;
    armv6l|armv6) echo "armv6" ;;
    armv5l|armv5) echo "armv5" ;;
    i386|i486|i586|i686|x86) echo "386" ;;
    mips64el|mips64le) echo "mips64le" ;;
    mips64) echo "mips64" ;;
    mipsel|mipsle) echo "mipsle-softfloat" ;;
    mips) echo "mips-softfloat" ;;
    ppc64le) echo "ppc64le" ;;
    riscv64) echo "riscv64" ;;
    s390x) echo "s390x" ;;
    loongarch64|loong64) echo "loong64-abi2" ;;
    *) return 1 ;;
  esac
}

latest_mihomo_tag() {
  local tag="${MHSWITCH_MIHOMO_VERSION:-}"
  if [[ -n "$tag" ]]; then
    [[ "$tag" == v* ]] || tag="v$tag"
    echo "$tag"
    return 0
  fi

  tag="$(curl -fsSIL --connect-timeout 10 --max-time 30 --retry 2 \
    -A 'mhswitch/1.0' "$MIHOMO_RELEASE_LATEST_URL" \
    | sed -n 's#^[Ll]ocation: .*/tag/\([^[:space:]\r]*\).*#\1#p' \
    | tail -n 1)"
  [[ -n "$tag" ]] || {
    ui_error "无法确定 Mihomo 最新稳定版本"
    return 1
  }
  echo "$tag"
}

mihomo_binary_works() {
  local bin="$1"
  [[ -x "$bin" ]] && "$bin" -v >/dev/null 2>&1
}

install_mihomo() {
  need_cmd curl
  need_cmd gzip

  local os arch tag asset url target tmp_dir archive candidate version
  os="$(uname -s)"
  [[ "$os" == "Linux" ]] || {
    ui_error "自动安装目前仅支持 Linux，当前系统: $os"
    return 1
  }
  arch="$(mihomo_asset_arch)" || {
    ui_error "不支持的 CPU 架构: $(uname -m)"
    return 1
  }

  if [[ -n "${MHSWITCH_MIHOMO_DOWNLOAD_URL:-}" ]]; then
    url="$MHSWITCH_MIHOMO_DOWNLOAD_URL"
    version="自定义安装包"
  else
    tag="$(latest_mihomo_tag)" || return 1
    # amd64 明确选择 GOAMD64 v1，兼容不支持较新指令集的 x86_64 CPU。
    if [[ "$arch" == "amd64" ]]; then
      asset="mihomo-linux-amd64-v1-${tag}.gz"
    else
      asset="mihomo-linux-${arch}-${tag}.gz"
    fi
    url="${MIHOMO_RELEASE_BASE_URL}/${tag}/${asset}"
    version="$tag"
  fi

  target="$MIHOMO_INSTALL_DIR/mihomo"
  tmp_dir="$(mktemp -d)"
  archive="$tmp_dir/mihomo.gz"
  candidate="$tmp_dir/mihomo"

  ui_title "安装 Mihomo"
  ui_kv "版本" "$version"
  ui_kv "架构" "$arch"
  ui_kv "位置" "$target"
  ui_run "从官方发布页下载安装包"

  if ! curl -fL --connect-timeout 15 --max-time 180 --retry 3 \
      -A 'mhswitch/1.0' "$url" -o "$archive"; then
    rm -rf "$tmp_dir"
    ui_error "Mihomo 下载失败"
    ui_info "下载地址: $url"
    ui_end
    return 1
  fi
  if ! gzip -t "$archive" || ! gzip -dc "$archive" > "$candidate"; then
    rm -rf "$tmp_dir"
    ui_error "安装包损坏或格式不正确"
    ui_end
    return 1
  fi
  chmod 0755 "$candidate"
  if ! mihomo_binary_works "$candidate"; then
    rm -rf "$tmp_dir"
    ui_error "下载的 Mihomo 无法在当前系统运行"
    ui_end
    return 1
  fi

  mkdir -p "$MIHOMO_INSTALL_DIR"
  mv -f "$candidate" "$target"
  rm -rf "$tmp_dir"
  MIHOMO_BIN="$target"
  ui_ok "Mihomo 安装完成"
  ui_kv "程序" "$target"
  ui_kv "版本" "$("$target" -v 2>/dev/null | head -n 1)"
  ui_end
}

find_mihomo_bin() {
  if [[ -n "$MIHOMO_BIN" && -x "$MIHOMO_BIN" ]]; then echo "$MIHOMO_BIN"; return 0; fi
  if command -v mihomo >/dev/null 2>&1; then command -v mihomo; return 0; fi
  if command -v clash-meta >/dev/null 2>&1; then command -v clash-meta; return 0; fi
  if [[ -x "$MIHOMO_INSTALL_DIR/mihomo" ]]; then echo "$MIHOMO_INSTALL_DIR/mihomo"; return 0; fi
  return 1
}

ensure_mihomo_installed() {
  local bin=""
  if bin="$(find_mihomo_bin 2>/dev/null)" && mihomo_binary_works "$bin"; then
    MIHOMO_BIN="$bin"
    return 0
  fi
  [[ -z "$bin" ]] || ui_warn "检测到的 Mihomo 无法运行，将重新安装"
  install_mihomo
}

state_has_airports() {
  local id name url exclude
  while IFS=$'\t' read -r id name url exclude; do
    [[ -n "$id" ]] && return 0
  done < <(state_iter)
  return 1
}

first_run_setup() {
  state_has_airports && return 0

  if ! is_interactive_tty; then
    ui_warn "尚未配置机场；非交互启动将使用直连配置"
    ui_info "添加订阅: mhswitch add <订阅URL> [名称]"
    return 0
  fi

  ui_title "首次启动设置"
  ui_info "请输入机场订阅链接；链接仅保存在本机状态文件中。"
  ui_info "直接回车可暂时跳过，稍后使用 mhswitch add 添加。"
  ui_end

  local url
  url="$(panel_prompt "机场订阅 URL")" || return 1
  if [[ -z "$url" ]]; then
    ui_warn "已跳过机场配置，将以直连模式启动"
    return 0
  fi
  add_airport "$url"
}

start_managed_mihomo() {
  ensure_mihomo_installed || return 1
  first_run_setup || return 1
  generate_config
  start_mihomo
}

start_mihomo() {
  if controller_alive; then
    ui_ok "Mihomo 已在运行"
    ui_kv "控制器" "$CONTROLLER"
    return 0
  fi

  ensure_mihomo_installed || return 1
  local bin="$MIHOMO_BIN"

  ui_title "启动 Mihomo"
  ui_kv "程序" "$bin"
  ui_kv "配置" "$CONFIG_FILE"
  ui_kv "日志" "$BASE_DIR/mihomo.log"

  nohup "$bin" -d "$BASE_DIR" -f "$CONFIG_FILE" >"$BASE_DIR/mihomo.log" 2>&1 &
  echo $! > "$PID_FILE"

  for _ in {1..20}; do
    sleep 0.5
    if controller_alive; then
      ui_ok "启动成功"
      ui_kv "控制器" "$CONTROLLER"
      ui_end
      return 0
    fi
  done

  ui_error "启动超时或失败"
  ui_info "查看日志: mhswitch log"
  ui_end
  return 1
}

stop_mihomo() {
  if [[ -f "$PID_FILE" ]]; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
  else
    pkill -f "mihomo -d $BASE_DIR" || true
  fi
  ui_ok "Mihomo 已停止"
}

# ----------------- Core Logic -----------------
download_subscription() {
  local src="$1" dest="$2"
  src="${src/#\~/$HOME}"
  # 伪装成 Clash Meta 客户端并支持 Gzip 解压，确保机场下发 YAML 而不是 Base64 乱码。
  local ua="clash-meta/1.18.0"
  if [[ "$src" =~ ^https?:// ]]; then
    # 默认直接忽略系统代理，强制直连下载订阅。
    curl -fL -A "$ua" --compressed --noproxy "*" --connect-timeout 10 --max-time 60 --retry 3 "$src" -o "$dest" || return 1
  elif [[ "$src" =~ ^file:// ]]; then
    cp "${src#file://}" "$dest" || return 1
  elif [[ -f "$src" ]]; then
    cp "$src" "$dest" || return 1
  else
    ui_error "无效的订阅路径或 URL：$src"
    return 1
  fi
}

# 分析订阅并提取信息，支持自动识别机场名称。
analyze_sub() {
  local full_file="$1" provider_file="$2" default_name="${3:-}" id="$4"
  python3 - "$full_file" "$provider_file" "$default_name" "$id" <<'PY'
import json, os, re, sys
full_file, provider_file, default_name, aid = sys.argv[1:5]
text = open(full_file, 'r', encoding='utf-8', errors='ignore').read()
lines = text.splitlines()

start, end = None, len(lines)
for i, line in enumerate(lines):
    if re.match(r'^\s*proxies\s*:\s*$', line):
        start = i
        break
if start is None:
    sys.exit('未找到 proxies: 字段')
for j in range(start + 1, len(lines)):
    if re.match(r'^[a-zA-Z0-9]', lines[j]):
        end = j
        break

block = lines[start:end]
os.makedirs(os.path.dirname(provider_file), exist_ok=True)
with open(provider_file, 'w', encoding='utf-8') as f:
    f.write('\n'.join(block).rstrip() + '\n')

proxy_names = []
for line in block[1:]:
    m = re.search(r'name:\s*(?:\'([^\']+)\'|"([^"]+)"|([^,}]+))', line)
    if m:
        proxy_names.append(next(x for x in m.groups() if x).strip())

detected_name = default_name
if not detected_name:
    pg_idx = None
    for i, line in enumerate(lines):
        if re.match(r'^\s*proxy-groups\s*:\s*$', line):
            pg_idx = i
            break
    if pg_idx is not None:
        for line in lines[pg_idx+1:]:
            if re.match(r'^[a-zA-Z0-9]', line):
                break
            m = re.search(r'^\s*-\s*\{\s*name:\s*(?:\'([^\']+)\'|"([^"]+)"|([^,}]+))', line)
            if not m:
                m = re.search(r'^\s*-\s*name:\s*(?:\'([^\']+)\'|"([^"]+)"|(.+))', line)
            if m:
                raw = next(x for x in m.groups() if x).strip()
                if raw not in ['PROXIES', 'DIRECT', 'REJECT', 'Fallback', 'Auto', '自动选择', '节点选择']:
                    raw = re.sub(r'^(🚀|✈️|☁️|💡|✨|🌟|🎈|🦄|🌐)\s*', '', raw)
                    detected_name = raw
                    break
    if not detected_name and proxy_names:
        detected_name = f"Airport_{aid}"

patterns = ['防失联', '剩余流量', '套餐到期', '如无可用', '官网下载', '官网', '测试', '距离下次重置', '过期时间']
found = [p for p in patterns if any(p in name for name in proxy_names)]
exclude_regex = '|'.join(re.escape(p) for p in found)

print(json.dumps({
    'name': detected_name,
    'exclude_regex': exclude_regex,
    'count': len(proxy_names)
}, ensure_ascii=False))
PY
}

add_airport() {
  local url="$1" custom_name="${2:-}"
  local tmp_full tmp_prov meta new_name exclude count target_id

  tmp_full="$(mktemp)"
  tmp_prov="$(mktemp)"

  ui_title "添加/更新机场"
  ui_run "拉取订阅"
  download_subscription "$url" "$tmp_full" || { rm -f "$tmp_full" "$tmp_prov"; return 1; }

  meta="$(analyze_sub "$tmp_full" "$tmp_prov" "$custom_name" "tmp")" || {
    ui_error "解析订阅失败，请检查 URL 或订阅格式"
    rm -f "$tmp_full" "$tmp_prov"
    return 1
  }

  new_name="$(echo "$meta" | python3 -c "import sys,json; print(json.load(sys.stdin)['name'])")"
  exclude="$(echo "$meta" | python3 -c "import sys,json; print(json.load(sys.stdin)['exclude_regex'])")"
  count="$(echo "$meta" | python3 -c "import sys,json; print(json.load(sys.stdin)['count'])")"

  target_id=$(python3 - "$STATE_FILE" "$new_name" "$url" <<'PY'
import json, sys
try:
    with open(sys.argv[1], encoding='utf-8') as f:
        data = json.load(f)
    for a in data.get('airports', []):
        if a['name'] == sys.argv[2] or a.get('url') == sys.argv[3]:
            print(a['id'])
            sys.exit(0)
except Exception:
    pass
PY
)

  if [[ -z "$target_id" ]]; then
    target_id="a_$(date +%s)_$RANDOM"
    ui_ok "添加新机场成功"
    ui_kv "机场" "$new_name"
    ui_kv "节点数" "$count"
  else
    ui_ok "发现已有机场，已覆盖更新"
    ui_kv "机场" "$new_name"
    ui_kv "节点数" "$count"
  fi

  mv "$tmp_full" "$(full_abs "$target_id")"
  mv "$tmp_prov" "$(provider_abs "$target_id")"

  python3 - "$STATE_FILE" "$target_id" "$new_name" "$url" "$exclude" <<'PY'
import json, sys
path, aid, name, url, ex = sys.argv[1:6]
try:
    with open(path, encoding='utf-8') as f:
        data = json.load(f)
except Exception:
    data = {'airports': []}

found = False
for a in data.get('airports', []):
    if a['id'] == aid:
        a['name'] = name
        a['url'] = url
        a['exclude_regex'] = ex
        found = True
        break

if not found:
    if 'airports' not in data:
        data['airports'] = []
    data['airports'].append({
        'id': aid,
        'name': name,
        'url': url,
        'exclude_regex': ex,
        'aliases': []
    })

with open(path, 'w', encoding='utf-8') as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
PY

  ui_end
  generate_config && reload_config
}

generate_config() {
  local cfg_tmp
  cfg_tmp="$(mktemp)"
  {
    cat <<'EOF'
mixed-port: 17890
allow-lan: false
mode: rule
log-level: info
external-controller: 127.0.0.1:9090
dns:
  enable: true
  use-hosts: true
  nameserver: [119.29.29.29, 223.5.5.5, tls://dns.google:853]
proxy-providers:
EOF

    local has_airport=0
    local all_ids=""
    local all_excludes=""

    while IFS=$'\t' read -r id name url exclude; do
      local pabs
      pabs="$(provider_abs "$id")"
      [[ -s "$pabs" ]] || continue
      has_airport=1
      all_ids="$all_ids, $id"
      if [[ -n "$exclude" ]]; then
        [[ -z "$all_excludes" ]] && all_excludes="$exclude" || all_excludes="$all_excludes|$exclude"
      fi
      cat <<EOF
  ${id}:
    type: file
    path: $(json_quote "$pabs")
    health-check:
      enable: true
      url: https://www.gstatic.com/generate_204
      interval: ${FAILOVER_INTERVAL_DEFAULT}
      timeout: ${FAILOVER_TIMEOUT_DEFAULT}
      lazy: ${FAILOVER_LAZY_DEFAULT}
EOF
    done < <(state_iter)

    echo -e "\nproxy-groups:"

    if [[ $has_airport -eq 1 ]]; then
      all_ids="${all_ids:2}"
      local ai_all_excludes
      ai_all_excludes="$(merge_regex "$all_excludes" "$AI_EXCLUDE_FILTER")"

      # ---------------- 全局故障切换节点：普通流量可用，允许所有地区。只在当前节点 timeout / 不可用时切换。 ----------------
      echo "  - name: $(json_quote "最优节点")"
      echo "    type: fallback"
      echo "    use: [$all_ids]"
      [[ -n "$all_excludes" ]] && echo "    exclude-filter: $(json_quote "$all_excludes")"
      echo "    url: https://www.gstatic.com/generate_204"
      echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
      echo "    timeout: ${FAILOVER_TIMEOUT_DEFAULT}"
      echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

      # ---------------- AI 地区故障切换：Claude / OpenAI / Codex 固定地区，不固定节点。只在当前节点 timeout / 不可用时切换。 ----------------
      echo "  - name: $(json_quote "Claude-${AI_REGION_NAME}-最优")"
      echo "    type: fallback"
      echo "    use: [$all_ids]"
      echo "    filter: $(json_quote "$AI_REGION_FILTER")"
      [[ -n "$all_excludes" ]] && echo "    exclude-filter: $(json_quote "$all_excludes")"
      echo "    url: $(json_quote "$CLAUDE_TEST_URL")"
      echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
      echo "    timeout: ${FAILOVER_TIMEOUT_DEFAULT}"
      echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

      echo "  - name: $(json_quote "OpenAI-${AI_REGION_NAME}-最优")"
      echo "    type: fallback"
      echo "    use: [$all_ids]"
      echo "    filter: $(json_quote "$AI_REGION_FILTER")"
      [[ -n "$ai_all_excludes" ]] && echo "    exclude-filter: $(json_quote "$ai_all_excludes")"
      echo "    url: $(json_quote "$OPENAI_TEST_URL")"
      echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
      echo "    timeout: ${OPENAI_TEST_TIMEOUT_DEFAULT}"
      echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

      # OpenAI 全地区兜底组：仍用 OpenAI/ChatGPT 地址检测，但不限制地区。
      # 当固定地区候选全部失败时，OpenAI-可用优先 会退到这里，避免长期粘住坏节点。
      echo "  - name: $(json_quote "$OPENAI_GLOBAL_GROUP")"
      echo "    type: fallback"
      echo "    use: [$all_ids]"
      [[ -n "$ai_all_excludes" ]] && echo "    exclude-filter: $(json_quote "$ai_all_excludes")"
      echo "    url: $(json_quote "$OPENAI_TEST_URL")"
      echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
      echo "    timeout: ${OPENAI_TEST_TIMEOUT_DEFAULT}"
      echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

      # OpenAI 自动兜底组：优先固定地区；固定地区全挂时，退到全地区 OpenAI 检测组；再退到普通最优。
      echo "  - name: $(json_quote "$OPENAI_AUTO_GROUP")"
      echo "    type: fallback"
      echo "    proxies:"
      echo "      - $(json_quote "OpenAI-${AI_REGION_NAME}-最优")"
      echo "      - $(json_quote "$OPENAI_GLOBAL_GROUP")"
      echo "      - $(json_quote "最优节点")"
      echo "      - DIRECT"
      echo "    url: $(json_quote "$OPENAI_TEST_URL")"
      echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
      echo "    timeout: ${OPENAI_TEST_TIMEOUT_DEFAULT}"
      echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

      # 兼容旧名字：如果你之前选择过 Claude-最优 / OpenAI-最优，仍可使用。
      echo "  - name: $(json_quote "Claude-最优")"
      echo "    type: select"
      echo "    proxies:"
      echo "      - $(json_quote "Claude-${AI_REGION_NAME}-最优")"

      echo "  - name: $(json_quote "OpenAI-最优")"
      echo "    type: select"
      echo "    proxies:"
      echo "      - $(json_quote "$OPENAI_AUTO_GROUP")"
      echo "      - $(json_quote "OpenAI-${AI_REGION_NAME}-最优")"
      echo "      - $(json_quote "$OPENAI_GLOBAL_GROUP")"

      # 动态生成各个机场的专属组。
      while IFS=$'\t' read -r id name url exclude; do
        [[ -s "$(provider_abs "$id")" ]] || continue

        # 普通自动组：所有地区节点故障切换。只在当前节点 timeout / 不可用时切换。
        echo "  - name: $(json_quote "${name}-自动")"
        echo "    type: fallback"
        echo "    use: [${id}]"
        [[ -n "$exclude" ]] && echo "    exclude-filter: $(json_quote "$exclude")"
        echo "    url: https://www.gstatic.com/generate_204"
        echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
        echo "    timeout: ${FAILOVER_TIMEOUT_DEFAULT}"
        echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

        # 普通手动组：用户手动选具体节点。
        echo "  - name: $(json_quote "${name}-手动")"
        echo "    type: select"
        echo "    use: [${id}]"
        [[ -n "$exclude" ]] && echo "    exclude-filter: $(json_quote "$exclude")"

        # Claude 单机场地区组：固定地区，在该机场同地区节点中故障切换。
        echo "  - name: $(json_quote "Claude-${name}-${AI_REGION_NAME}")"
        echo "    type: fallback"
        echo "    use: [${id}]"
        echo "    filter: $(json_quote "$AI_REGION_FILTER")"
        [[ -n "$exclude" ]] && echo "    exclude-filter: $(json_quote "$exclude")"
        echo "    url: $(json_quote "$CLAUDE_TEST_URL")"
        echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
        echo "    timeout: ${FAILOVER_TIMEOUT_DEFAULT}"
        echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

        # OpenAI / Codex 单机场地区组：固定地区，在该机场同地区节点中故障切换。
        local ai_exclude
        ai_exclude="$(merge_regex "$exclude" "$AI_EXCLUDE_FILTER")"
        echo "  - name: $(json_quote "OpenAI-${name}-${AI_REGION_NAME}")"
        echo "    type: fallback"
        echo "    use: [${id}]"
        echo "    filter: $(json_quote "$AI_REGION_FILTER")"
        [[ -n "$ai_exclude" ]] && echo "    exclude-filter: $(json_quote "$ai_exclude")"
        echo "    url: $(json_quote "$OPENAI_TEST_URL")"
        echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
        echo "    timeout: ${OPENAI_TEST_TIMEOUT_DEFAULT}"
        echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

        # OpenAI / Codex 单机场全地区组：限定同一机场，但不限制地区。
        echo "  - name: $(json_quote "OpenAI-${name}-全地区-最优")"
        echo "    type: fallback"
        echo "    use: [${id}]"
        [[ -n "$ai_exclude" ]] && echo "    exclude-filter: $(json_quote "$ai_exclude")"
        echo "    url: $(json_quote "$OPENAI_TEST_URL")"
        echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
        echo "    timeout: ${OPENAI_TEST_TIMEOUT_DEFAULT}"
        echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"

        # OpenAI / Codex 单机场可用优先组：同一机场内固定地区优先，失败时退到该机场全地区。
        echo "  - name: $(json_quote "OpenAI-${name}-可用优先")"
        echo "    type: fallback"
        echo "    proxies:"
        echo "      - $(json_quote "OpenAI-${name}-${AI_REGION_NAME}")"
        echo "      - $(json_quote "OpenAI-${name}-全地区-最优")"
        echo "      - $(json_quote "${name}-自动")"
        echo "      - DIRECT"
        echo "    url: $(json_quote "$OPENAI_TEST_URL")"
        echo "    interval: ${FAILOVER_INTERVAL_DEFAULT}"
        echo "    timeout: ${OPENAI_TEST_TIMEOUT_DEFAULT}"
        echo "    lazy: ${FAILOVER_LAZY_DEFAULT}"
      done < <(state_iter)

      # 聚合默认代理组：普通流量默认走全局故障切换组，可手动切机场。
      echo "  - name: $(json_quote "默认代理")"
      echo "    type: select"
      echo "    proxies:"
      echo "      - $(json_quote "最优节点")"
      echo "      - DIRECT"
      while IFS=$'\t' read -r id name url exclude; do
        [[ -s "$(provider_abs "$id")" ]] || continue
        echo "      - $(json_quote "${name}-自动")"
        echo "      - $(json_quote "${name}-手动")"
      done < <(state_iter)

      # 聚合 Claude 组：默认固定 AI_REGION_NAME 地区，在该地区内故障切换。
      echo "  - name: $(json_quote "Claude")"
      echo "    type: select"
      echo "    proxies:"
      echo "      - $(json_quote "Claude-${AI_REGION_NAME}-最优")"
      while IFS=$'\t' read -r id name url exclude; do
        [[ -s "$(provider_abs "$id")" ]] || continue
        echo "      - $(json_quote "Claude-${name}-${AI_REGION_NAME}")"
      done < <(state_iter)
      echo "      - REJECT"

      # 聚合 OpenAI / Codex 组：默认“固定地区优先 + 全地区兜底”，避免固定地区全挂时卡死在坏节点。
      echo "  - name: $(json_quote "OpenAI")"
      echo "    type: select"
      echo "    proxies:"
      echo "      - $(json_quote "$OPENAI_AUTO_GROUP")"
      echo "      - $(json_quote "OpenAI-${AI_REGION_NAME}-最优")"
      echo "      - $(json_quote "$OPENAI_GLOBAL_GROUP")"
      while IFS=$'	' read -r id name url exclude; do
        [[ -s "$(provider_abs "$id")" ]] || continue
        echo "      - $(json_quote "OpenAI-${name}-可用优先")"
        echo "      - $(json_quote "OpenAI-${name}-${AI_REGION_NAME}")"
        echo "      - $(json_quote "OpenAI-${name}-全地区-最优")"
      done < <(state_iter)
      echo "      - $(json_quote "Claude-${AI_REGION_NAME}-最优")"
      echo "      - $(json_quote "最优节点")"
      echo "      - DIRECT"

      # Git Clone 组：可在 DIRECT / 默认代理 / 最优节点 / 单机场自动之间切换。
      echo "  - name: $(json_quote "$GIT_GROUP_NAME")"
