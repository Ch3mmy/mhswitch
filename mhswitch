# ----------------- Command Dispatcher -----------------
init_state
if [[ $# -eq 0 && -t 0 && -t 1 ]]; then
  cmd="panel"
else
  cmd="${1:-status}"
fi

case "$cmd" in
  panel|ui|menu|控制面板)
    panel_main
    ;;

  status) show_status ;;
  list) show_status ;;

  add)
    [[ $# -ge 2 ]] || { ui_error "用法: mhswitch add <URL> [自定义名称]"; exit 1; }
    add_airport "$2" "${3:-}"
    ;;

  remove)
    [[ $# -ge 2 ]] || { ui_error "用法: mhswitch remove <机场名>"; exit 1; }
    id="$(resolve_id "$2")" || { ui_error "未找到机场: $2"; exit 1; }
    state_remove "$id"
    generate_config && reload_config
    ui_ok "机场已删除"
    ui_kv "机场" "$2"
    ;;

  update)
    refresh_all
    ;;

  nodes|node-list|list-nodes|机场节点)
    list_nodes "${2:-all}"
    ;;

  proxy)
    [[ $# -ge 2 ]] || { ui_error "用法: mhswitch proxy <机场名> [auto|manual]"; exit 1; }
    id="$(resolve_id "$2")" || { ui_error "未找到机场: $2"; exit 1; }
    name="$(state_iter | grep "^$id" | cut -f2)"
    mode="${3:-auto}"
    case "$mode" in
      auto|自动) target="${name}-自动" ;;
      manual|手动) target="${name}-手动" ;;
      *) ui_error "第二个参数必须是 auto 或 manual"; exit 1 ;;
    esac
    set_group_proxy "默认代理" "$target"
    ;;

  claude)
    target_arg="${2:-best}"
    case "$target_arg" in
      best|auto|all|全部|最优)
        set_group_proxy "Claude" "Claude-${AI_REGION_NAME}-最优"
        ;;
      *)
        id="$(resolve_id "$target_arg")" || { ui_error "未找到机场: $target_arg"; exit 1; }
        name="$(state_iter | grep "^$id" | cut -f2)"
        set_group_proxy "Claude" "Claude-${name}-${AI_REGION_NAME}"
        ;;
    esac
    ;;

  openai|codex)
    target_arg="${2:-}"
    rule_arg="${3:-}"
    if [[ -z "$target_arg" ]]; then
      if is_interactive_tty; then
        OPENAI_TARGET_SELECTION=""
        choose_openai_target_interactive || exit $?
        set_group_proxy "OpenAI" "$OPENAI_TARGET_SELECTION"
      else
        set_group_proxy "OpenAI" "$OPENAI_AUTO_GROUP"
      fi
      exit $?
    fi

    case "$target_arg" in
      select|choose|pick|menu|选择|机场)
        OPENAI_TARGET_SELECTION=""
        choose_openai_target_interactive || exit $?
        set_group_proxy "OpenAI" "$OPENAI_TARGET_SELECTION"
        ;;
      best|auto|all|全部|最优)
        set_group_proxy "OpenAI" "$OPENAI_AUTO_GROUP"
        ;;
      strict|region|fixed|固定|固定地区)
        set_group_proxy "OpenAI" "OpenAI-${AI_REGION_NAME}-最优"
        ;;
      global|any|all-region|全局|全地区)
        set_group_proxy "OpenAI" "$OPENAI_GLOBAL_GROUP"
        ;;
      direct|DIRECT|直连)
        set_group_proxy "OpenAI" "DIRECT"
        ;;
      *)
        id="$(resolve_id "$target_arg")" || { ui_error "未找到机场: $target_arg"; exit 1; }
        name="$(state_iter | grep "^$id" | cut -f2)"
        case "$rule_arg" in
          ""|strict|region|fixed|固定|固定地区)
            set_group_proxy "OpenAI" "OpenAI-${name}-${AI_REGION_NAME}"
            ;;
          auto|best|优先|可用优先|兜底|最优)
            set_group_proxy "OpenAI" "OpenAI-${name}-可用优先"
            ;;
          global|any|all-region|全局|全地区)
            set_group_proxy "OpenAI" "OpenAI-${name}-全地区-最优"
            ;;
          direct|DIRECT|直连)
            set_group_proxy "OpenAI" "DIRECT"
            ;;
          *)
            ui_error "机场后的规则必须是 auto、strict、global 或 direct"
            exit 1
            ;;
        esac
        ;;
    esac
    ;;

  mode)
    [[ $# -ge 2 ]] || { ui_error "用法: mhswitch mode <rule|global|direct>"; exit 1; }
    set_mode "$2"
    ;;

  flush)
    flush_connections
    ;;

  git|git-clone)
    set_git_clone_proxy "${2:-status}"
    ;;

  delay|latency|test)
    run_delay "${2:-all}" "${3:-$DELAY_URL_DEFAULT}" "${4:-$DELAY_TIMEOUT_DEFAULT}" "${5:-$DELAY_JOBS_DEFAULT}"
    ;;

  openai-test|chatgpt-test)
    run_openai_test "${2:-all}" "${3:-$OPENAI_TEST_TIMEOUT_DEFAULT}" "${4:-$DELAY_JOBS_DEFAULT}"
    ;;

  install)
    if bin="$(find_mihomo_bin 2>/dev/null)" && mihomo_binary_works "$bin"; then
      ui_ok "Mihomo 已正确安装"
      ui_kv "程序" "$bin"
      ui_kv "版本" "$("$bin" -v 2>/dev/null | head -n 1)"
    else
      install_mihomo
    fi
    ;;

  start)
    start_managed_mihomo
    ;;

  stop)
    stop_mihomo
    ;;

  restart)
    ui_title "重启 Mihomo"
    stop_mihomo
    sleep 1
    start_managed_mihomo
    ui_end
    ;;

  reload)
    generate_config
    reload_config
    ;;

  log)
    if [[ -f "$BASE_DIR/mihomo.log" ]]; then
      ui_info "查看日志: $BASE_DIR/mihomo.log"
      tail -f "$BASE_DIR/mihomo.log"
    else
      ui_warn "暂无日志文件"
    fi
    ;;

  -h|--help|help)
    show_help
    ;;

  *)
    ui_error "未知命令: $cmd"
    show_help
    exit 1
    ;;
esac
