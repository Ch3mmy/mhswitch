          echo "      - $(json_quote "$GIT_PROXY_DEFAULT")"
          echo "      - DIRECT"
          echo "      - $(json_quote "默认代理")"
          echo "      - $(json_quote "最优节点")"
          ;;
      esac
      while IFS=$'\t' read -r id name url exclude; do
        [[ -s "$(provider_abs "$id")" ]] || continue
        echo "      - $(json_quote "${name}-自动")"
        echo "      - $(json_quote "${name}-手动")"
      done < <(state_iter)
    else
      echo "  - name: 默认代理"
      echo "    type: select"
      echo "    proxies: [DIRECT]"
      echo "  - name: Claude"
      echo "    type: select"
      echo "    proxies: [DIRECT, REJECT]"
